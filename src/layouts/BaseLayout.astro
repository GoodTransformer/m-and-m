---
import { type Locale } from '../lib/i18n';
import { getStrings } from '../i18n';
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';

// Self-hosted fonts (Fontsource). Fraunces "standard" carries the weight +
// optical-size axes; EB Garamond carries weight. Italics imported separately.
import '@fontsource-variable/fraunces/standard.css';
import '@fontsource-variable/fraunces/standard-italic.css';
import '@fontsource-variable/eb-garamond/index.css';
import '@fontsource-variable/eb-garamond/wght-italic.css';

import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/typography.css';

interface Props {
  locale: Locale;
  path: string; // logical path, e.g. "/venues"
  title?: string;
  description?: string;
  mainClass?: string;
}
const { locale, path, title, description, mainClass = '' } = Astro.props;
const t = getStrings(locale);

const pageTitle = title ? `${title} — Mari & Michael` : t.meta.title;
const pageDesc = description ?? t.meta.description;
const ogImage = new URL(`${import.meta.env.BASE_URL}og.png`, Astro.site ?? 'https://example.com').href;
const faviconHref = `${import.meta.env.BASE_URL}favicon.svg`;
---

<!doctype html>
<html lang={locale} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />

    <!-- Private preview: keep the site out of search results. -->
    <meta name="robots" content="noindex, nofollow" />

    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#f2e8d8" />
    <link rel="icon" href={faviconHref} type="image/svg+xml" />

    <!-- Social preview (for sharing the link privately) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={locale === 'es' ? 'es_ES' : 'en_GB'} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Without JS, reveal-on-scroll elements must still be visible. -->
    <noscript>
      <style>
        .reveal {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>

    <slot name="head" />
  </head>
  <body>
    <!-- Non-sticky anchor for the footer "back to top" link. Must NOT live on the
         sticky masthead, or scrolling to it from the bottom barely moves (the
         header is already pinned at the viewport top). -->
    <span id="top" aria-hidden="true"></span>
    <a class="skip-link" href="#main">Skip to content</a>
    <Masthead locale={locale} path={path} />
    <main id="main" class={mainClass}>
      <slot />
    </main>
    <Footer locale={locale} path={path} />

    <script>
      // Gentle reveal-on-scroll. Fully skipped under reduced-motion (CSS already
      // shows everything), and degrades to visible if IO is unavailable.
      const els = Array.from(document.querySelectorAll<HTMLElement>('.reveal'));
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) {
        els.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
