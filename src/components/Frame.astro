---
// A real photograph, framed to match the site's "plate" aesthetic. Astro's
// pipeline (Sharp) emits WebP at several widths with a `sizes` hint, so each
// device downloads only what it displays — phones get a small file, retina
// desktops a crisp one. Intrinsic width/height are baked in (zero layout shift),
// and the warm frame background shows while the bytes arrive, so nothing flashes
// white. Lazy by default; eager images are also fetch-prioritised.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  ratio?: string;
  /** Max display width (px). Caps the generated set; never upscales past source. */
  width?: number;
  /** Responsive sizes hint. Default suits the half-width splits used on the site. */
  sizes?: string;
  eager?: boolean;
  class?: string;
}
const {
  src,
  alt,
  ratio = '3/2',
  width = 1000,
  sizes = '(min-width: 48rem) 48vw, 92vw',
  eager = false,
  class: cls = '',
} = Astro.props;

// Never upscale past the source, then build a small ladder of widths up to that
// cap: phones pull ~400–640px, laptops the mid sizes, retina the full width.
const cap = Math.min(width, src.width);
const widths = [...new Set([400, 640, 960, 1280, cap])]
  .filter((w) => w <= cap)
  .sort((a, b) => a - b);
---

<figure class:list={['frame', cls]} style={`--ratio:${ratio}`}>
  <Image
    src={src}
    alt={alt}
    widths={widths}
    sizes={sizes}
    format="webp"
    quality={74}
    loading={eager ? 'eager' : 'lazy'}
    fetchpriority={eager ? 'high' : 'auto'}
    decoding="async"
  />
</figure>

<style>
  .frame {
    position: relative;
    margin: 0;
    width: 100%;
    aspect-ratio: var(--ratio);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--bg-card-edge);
    /* Mounted-plate feel: the resting shadow lifts the photo a hair off the page. */
    box-shadow: var(--shadow-rest);
  }
  /* Inner hairline drawn *over* the cover image, so the photo edge reads as
     matted rather than bleeding into the warm ground. */
  .frame::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--espresso) 8%, transparent);
    pointer-events: none;
  }
  .frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
</style>
