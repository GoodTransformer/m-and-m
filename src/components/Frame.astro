---
// A real photograph, framed to match the site's "plate" aesthetic. The image is
// run through Astro's pipeline (Sharp) → WebP, downscaled to `width`, with
// intrinsic dimensions baked in (zero layout shift). Lazy by default.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  ratio?: string;
  width?: number; // optimised output width cap (px); default 1000
  eager?: boolean;
  class?: string;
}
const { src, alt, ratio = '3/2', width = 1000, eager = false, class: cls = '' } = Astro.props;
// never upscale past the source
const outWidth = Math.min(width, src.width);
---

<figure class:list={['frame', cls]} style={`--ratio:${ratio}`}>
  <Image
    src={src}
    alt={alt}
    width={outWidth}
    format="webp"
    quality={74}
    loading={eager ? 'eager' : 'lazy'}
    decoding="async"
  />
</figure>

<style>
  .frame {
    margin: 0;
    width: 100%;
    aspect-ratio: var(--ratio);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--bg-card-edge);
  }
  .frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
</style>
