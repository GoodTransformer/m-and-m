---
// Hairline arrow icon — one source of truth, replacing the raw Unicode glyphs
// (↗ → ↑) that iOS/WebKit promote to coloured emoji. Inherits colour via
// currentColor and scales to surrounding text (em-sized). Decorative: aria-hidden.
// Geometry matches the Button external arrow so every arrow on the site is identical.
//   dir="ne"    external / "opens elsewhere"  (Google Maps, Read more)
//   dir="right" forward / "go to"             (language link, venue cards)
//   dir="up"    back-to-top
interface Props {
  dir?: 'ne' | 'right' | 'up';
  class?: string;
}
const { dir = 'ne', class: cls = '' } = Astro.props;
---

{
  dir === 'ne' && (
    <svg class:list={['arw', 'arw--ne', cls]} viewBox="0 0 12 12" aria-hidden="true" focusable="false">
      <line x1="2.5" y1="9.5" x2="9.5" y2="2.5" />
      <polyline points="4.5,2.5 9.5,2.5 9.5,7.5" />
    </svg>
  )
}
{
  dir === 'right' && (
    <svg class:list={['arw', 'arw--right', cls]} viewBox="0 0 24 12" aria-hidden="true" focusable="false">
      <line x1="0.5" y1="6" x2="21" y2="6" />
      <polyline points="17,2 21,6 17,10" />
    </svg>
  )
}
{
  dir === 'up' && (
    <svg class:list={['arw', 'arw--up', cls]} viewBox="0 0 12 14" aria-hidden="true" focusable="false">
      <line x1="6" y1="12.5" x2="6" y2="2" />
      <polyline points="2,6 6,2 10,6" />
    </svg>
  )
}

<style>
  .arw {
    flex: none;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.25;
    stroke-linecap: square;
    stroke-linejoin: miter;
    overflow: visible;
    transition: transform 0.3s var(--ease-soft);
  }
  .arw--ne {
    width: 0.78em;
    height: 0.78em;
    vertical-align: -0.02em;
  }
  .arw--right {
    width: 1.5em;
    height: 0.75em;
    vertical-align: middle;
    stroke-width: 1;
  }
  .arw--up {
    width: 0.72em;
    height: 0.84em;
    vertical-align: -0.08em;
    stroke-width: 1.1;
  }
</style>
