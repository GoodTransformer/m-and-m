---
// The homepage quick-action row — the practical actions, reachable in one tap,
// kept within the first screenful. Flows from 2 columns on mobile to a single
// refined row on desktop.
import Amp from './Amp.astro';

interface Item {
  href: string;
  label: string;
}
interface Props {
  items: Item[];
  ariaLabel: string;
  class?: string;
}
const { items, ariaLabel, class: cls = '' } = Astro.props;
---

<nav class:list={['quick', cls]} aria-label={ariaLabel} style={`--quick-cols:${items.length}`}>
  <ul class="quick__list">
    {
      items.map((item) => (
        <li class="quick__item">
          <a class="quick__link" href={item.href}>
            <span class="quick__label"><Amp text={item.label} /></span>
            <svg
              class="quick__arrow"
              viewBox="0 0 28 10"
              aria-hidden="true"
              focusable="false"
            >
              <line x1="0.5" y1="5" x2="23" y2="5" />
              <polyline points="19,1 23,5 19,9" />
            </svg>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .quick__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(0.5rem, 2vw, 0.85rem);
  }
  .quick__item {
    margin: 0;
  }

  .quick__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    height: 100%;
    min-height: 3.6rem;
    padding: 0.85rem 1.1rem;
    text-decoration: none;
    background: color-mix(in srgb, var(--candle-ivory) 60%, var(--old-parchment));
    border: 1px solid var(--bg-card-edge);
    border-radius: var(--radius);
    color: var(--text);
    box-shadow: var(--shadow-rest);
    transition:
      background-color 0.3s var(--ease-soft),
      border-color 0.3s var(--ease-soft),
      box-shadow 0.4s var(--ease-soft),
      transform 0.3s var(--ease-soft);
  }
  .quick__label {
    font-family: var(--font-display);
    font-size: clamp(1.02rem, 1.4vw, 1.18rem);
    font-weight: 450;
    line-height: 1.1;
  }
  /* Refined hairline arrow — thin, brass, lengthens slightly on hover. */
  .quick__arrow {
    width: 28px;
    height: 10px;
    color: var(--oxidised-bronze);
    fill: none;
    stroke: currentColor;
    stroke-width: 1;
    stroke-linecap: square;
    stroke-linejoin: miter;
    flex: none;
    overflow: visible;
    transition: color 0.3s var(--ease-soft), transform 0.3s var(--ease-soft);
  }
  @media (hover: hover) {
    .quick__link:hover {
      background: var(--bg-card);
      border-color: color-mix(in srgb, var(--oxidised-bronze) 55%, transparent);
      box-shadow: var(--shadow-soft);
      transform: translateY(-2px);
    }
    .quick__link:hover .quick__arrow {
      color: var(--accent);
      transform: translateX(4px);
    }
  }

  /* Desktop: an engraved index, not a button grid. The filled tiles give way to
     rows framed by hairlines, each entry a single line — label left, arrow
     right — like a line in a printed contents page. Two ruled rows of three
     from tablet up; one row of six once every label fits unwrapped. (Mobile
     keeps the tappable tiles; the row maths assume the homepage's six items.) */
  @media (min-width: 48rem) {
    .quick__list {
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      border-block: 1px solid var(--rule);
    }
    .quick__item + .quick__item {
      border-left: 1px solid var(--rule);
    }
    .quick__item:nth-child(3n + 1) {
      border-left: 0;
    }
    .quick__item:nth-child(-n + 3) {
      border-bottom: 1px solid var(--rule);
    }
    .quick__link {
      gap: 1rem;
      min-height: 0;
      padding: 1.2rem 1.35rem;
      background: transparent;
      border: 0;
      border-radius: 0;
      box-shadow: none;
    }
    /* Quiet hover: a breath of parchment fills the cell — no lift, no shadow. */
    .quick__link:hover {
      background: color-mix(in srgb, var(--old-parchment) 28%, transparent);
      box-shadow: none;
      transform: none;
    }
  }
  @media (min-width: 73rem) {
    .quick__list {
      /* minmax(max-content, 1fr): every entry is guaranteed its single line
         (Spanish runs longer — "Nuestra historia"), then spare width is shared
         out, so the columns sit near-equal like a contents page. */
      grid-template-columns: repeat(var(--quick-cols, 6), minmax(max-content, 1fr));
    }
    .quick__item:nth-child(3n + 1) {
      border-left: 1px solid var(--rule);
    }
    .quick__item:first-child {
      border-left: 0;
    }
    .quick__item:nth-child(-n + 3) {
      border-bottom: 0;
    }
    /* Six labels share one line: trim the cell padding and the type a touch so
       the longest entry ("Travel & Stay") holds a single line at 73rem. */
    .quick__link {
      gap: 0.6rem;
      padding-inline: 0.9rem;
    }
    .quick__label {
      font-size: 1.05rem;
    }
  }
</style>
