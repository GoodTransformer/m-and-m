---
// An art-directed placeholder, framed like a tipped-in plate in an art book.
// Holds exact dimensions (aspect-ratio) so swapping in a real <picture> later
// causes zero layout shift. `label` names the intended shot.
interface Props {
  ratio?: string; // e.g. "3/2", "4/5", "16/9"
  label: string;
  caption?: string;
  plate?: string; // small index, e.g. "I"
  tone?: 'light' | 'deep';
  reveal?: boolean;
  class?: string;
}
const {
  ratio = '3/2',
  label,
  caption,
  plate,
  tone = 'light',
  reveal = false,
  class: cls = '',
} = Astro.props;
---

<figure
  class:list={['plate', `plate--${tone}`, reveal && 'reveal', cls]}
  style={`--ratio:${ratio}`}
  aria-hidden="true"
>
  <div class="plate__inner">
    <span class="plate__mark">{plate ? `Plate ${plate}` : 'Image to come'}</span>
    <span class="plate__label">{label}</span>
    {caption && <span class="plate__caption">{caption}</span>}
  </div>
</figure>

<style>
  .plate {
    margin: 0;
    width: 100%;
    aspect-ratio: var(--ratio);
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
    background:
      radial-gradient(120% 90% at 22% 18%, color-mix(in srgb, var(--champagne-silk) 70%, white) 0%, transparent 55%),
      radial-gradient(140% 120% at 88% 110%, color-mix(in srgb, var(--dark-walnut) 55%, transparent) 0%, transparent 60%),
      linear-gradient(150deg, var(--old-parchment), var(--aged-linen));
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--oxidised-bronze) 30%, transparent),
      inset 0 0 0 7px color-mix(in srgb, var(--candle-ivory) 30%, transparent),
      inset 0 0 0 8px color-mix(in srgb, var(--antique-brass) 34%, transparent);
  }

  .plate--deep {
    background:
      radial-gradient(120% 90% at 22% 18%, color-mix(in srgb, var(--oxidised-bronze) 55%, transparent) 0%, transparent 55%),
      linear-gradient(150deg, var(--dark-walnut), var(--espresso));
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--antique-brass) 30%, transparent),
      inset 0 0 0 7px color-mix(in srgb, var(--espresso) 50%, transparent),
      inset 0 0 0 8px color-mix(in srgb, var(--antique-brass) 40%, transparent);
  }

  .plate__inner {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.5rem;
    text-align: center;
  }

  .plate__mark {
    font-family: var(--font-body);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.26em;
    color: color-mix(in srgb, var(--oxidised-bronze) 88%, transparent);
  }
  .plate--deep .plate__mark {
    color: color-mix(in srgb, var(--antique-brass) 92%, transparent);
  }

  .plate__label {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.05rem, 2.4vw, 1.5rem);
    line-height: 1.25;
    max-width: 28ch;
    color: color-mix(in srgb, var(--dark-walnut) 80%, transparent);
  }
  .plate--deep .plate__label {
    color: var(--candle-ivory);
  }

  .plate__caption {
    font-size: 0.82rem;
    color: var(--text-muted);
    max-width: 32ch;
  }
  .plate--deep .plate__caption {
    color: var(--text-muted-on-deep);
  }
</style>
