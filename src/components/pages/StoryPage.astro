---
import { type Locale } from '../../lib/i18n';
import { getStrings } from '../../i18n';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Chapter from '../Chapter.astro';
import Frame from '../Frame.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getStrings(locale);
---

<BaseLayout locale={locale} path="/our-story" title={t.nav.story}>
  <Chapter label={t.story.label} title={t.story.title} headingLevel="h1" center id="story">
    <div class="story">
      <figure class="story__media reveal">
        <Frame
          src="images/our-story.jpg"
          alt="A storybook cover, Bells Bells!, with Mari & Michael drawn among bell-ringers, wizards and a dragon above an Oxford square"
          width={990}
          height={1400}
          ratio="99 / 140"
          eager
          class="story__frame"
        />
        <figcaption>{t.story.caption}</figcaption>
      </figure>
      <div class="story__prose reveal">
        {t.story.body.map((p, i) => <p class={i === 0 ? 'dropcap' : undefined}>{p}</p>)}
      </div>
    </div>
  </Chapter>
</BaseLayout>

<style>
  .story {
    display: grid;
    gap: clamp(1.5rem, 5vw, 2rem);
    text-align: left;
    max-width: 52rem;
    margin-inline: auto;
  }
  .story__media {
    margin: 0;
    max-width: 22rem;
    margin-inline: auto;
    width: 100%;
  }
  .story__media figcaption {
    margin-top: 0.85rem;
    font-size: 0.85rem;
    font-style: italic;
    text-align: center;
    color: var(--text-muted, var(--text));
    opacity: 0.78;
  }
  .story__prose p {
    font-size: var(--fs-lead);
    line-height: 1.6;
  }
  .story__prose p + p {
    margin-top: 1em;
  }

  @media (min-width: 48rem) {
    .story {
      grid-template-columns: 0.82fr 1fr;
      align-items: start;
      gap: clamp(2.5rem, 5vw, 4.5rem);
    }
    .story__media {
      max-width: none;
      margin-inline: 0;
    }
  }
</style>
