---
import { type Locale, asset } from '../../lib/i18n';
import { getStrings } from '../../i18n';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Chapter from '../Chapter.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getStrings(locale);
---

<BaseLayout locale={locale} path="/our-story" title={t.nav.story}>
  <Chapter label={t.story.label} title={t.story.title} headingLevel="h1" center id="story">
    <div class="story">
      <figure class="story__media reveal">
        <img
          src={asset('images/our-story.jpg')}
          alt="A storybook cover, “Bells Bells!”, with Mari & Michael drawn among bell-ringers, wizards and a dragon above an Oxford square"
          loading="eager"
          decoding="async"
        />
        <figcaption>{t.story.caption}</figcaption>
      </figure>
      <div class="story__prose reveal">
        {t.story.body.map((p, i) => <p class={i === 0 ? 'dropcap' : undefined}>{p}</p>)}
      </div>
    </div>
  </Chapter>
</BaseLayout>

<style>
  .story {
    display: grid;
    gap: clamp(2rem, 6vw, 3.5rem);
    align-items: center;
    text-align: left;
    max-width: 52rem;
    margin-inline: auto;
  }
  .story__media {
    margin: 0;
    max-width: 22rem;
    margin-inline: auto;
  }
  .story__media img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--bg-card-edge);
    background: var(--bg-card);
    box-shadow: 0 1.25rem 2.5rem -1.25rem rgba(0, 0, 0, 0.5);
  }
  .story__media figcaption {
    margin-top: 0.85rem;
    font-size: var(--fs-fine, 0.8rem);
    font-style: italic;
    text-align: center;
    color: var(--ink-soft, inherit);
    opacity: 0.8;
  }
  .story__prose p {
    font-size: var(--fs-lead);
    line-height: 1.6;
  }
  .story__prose p + p {
    margin-top: 1em;
  }

  @media (min-width: 48rem) {
    .story {
      grid-template-columns: 0.7fr 1fr;
    }
    .story__media {
      max-width: none;
    }
  }
</style>
