---
import { type Locale } from '../../lib/i18n';
import { getStrings } from '../../i18n';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Chapter from '../Chapter.astro';
import Faq from '../Faq.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getStrings(locale);
---

<BaseLayout locale={locale} path="/questions" title={t.nav.questions}>
  <Chapter
    label={t.questions.label}
    title={t.questions.title}
    headingLevel="h1"
    id="questions"
  >
    <p class="lead measure reveal questions__intro">{t.questions.intro}</p>
    <Faq faqs={t.questions.faqs} class="reveal" />
    <p class="muted reveal questions__note">{t.questions.note}</p>
  </Chapter>
</BaseLayout>

<style>
  .questions__intro {
    margin-bottom: clamp(2rem, 5vw, 3rem);
  }
  .questions__note {
    margin-top: clamp(1.75rem, 4vw, 2.5rem);
    font-style: italic;
    max-width: 44ch;
  }
</style>
