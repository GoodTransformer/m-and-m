---
import { type Locale } from '../../lib/i18n';
import { getStrings } from '../../i18n';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Chapter from '../Chapter.astro';
import WeekendTimeline from '../WeekendTimeline.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getStrings(locale);
---

<BaseLayout locale={locale} path="/the-day" title={t.nav.weekend}>
  <Chapter
    label={t.weekend.label}
    title={t.weekend.title}
    headingLevel="h1"
    id="weekend"
  >
    <p class="lead measure reveal weekend__intro">{t.weekend.intro}</p>
    <div class="weekend__timeline reveal">
      <WeekendTimeline events={t.weekend.events} />
    </div>
    <p class="muted reveal weekend__closing">{t.weekend.closing}</p>
  </Chapter>
</BaseLayout>

<style>
  .weekend__intro {
    margin-bottom: clamp(2.25rem, 6vw, 3.5rem);
  }
  .weekend__closing {
    margin-top: clamp(1.5rem, 4vw, 2.5rem);
    font-style: italic;
    max-width: 40ch;
  }

  /* Desktop: a centred, paper-invitation composition. The schedule reads like a
     printed order of the day and fills the page, instead of hugging the left
     edge with a lopsided empty margin. Mobile keeps the left-aligned timeline. */
  @media (min-width: 48rem) {
    :global(#weekend .chapter__head) {
      margin-inline: auto;
      text-align: center;
      max-width: 46ch;
    }
    :global(#weekend .chapter__title) {
      margin-inline: auto;
    }
    .weekend__intro {
      margin-inline: auto;
      text-align: center;
      max-width: 52ch;
    }
    .weekend__closing {
      margin-inline: auto;
      text-align: center;
    }
  }
</style>
