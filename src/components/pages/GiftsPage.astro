---
import { type Locale } from '../../lib/i18n';
import { getStrings } from '../../i18n';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Chapter from '../Chapter.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getStrings(locale);
---

<BaseLayout locale={locale} path="/gifts" title={t.nav.gifts}>
  <Chapter
    label={t.gifts.label}
    numeral="V"
    title={t.gifts.title}
    headingLevel="h1"
    center
    id="gifts"
  >
    <div class="gifts reveal">
      {t.gifts.body.map((p) => <p class="gifts__p">{p}</p>)}

      <span class="gifts__wink" aria-hidden="true"></span>

      <p class="gifts__note">{t.gifts.note}</p>
    </div>
  </Chapter>
</BaseLayout>

<style>
  .gifts {
    max-width: 40ch;
    margin-inline: auto;
    text-align: center;
  }
  .gifts__p {
    font-size: var(--fs-lead);
    line-height: 1.55;
  }
  .gifts__p + .gifts__p {
    margin-top: 1.1em;
  }

  /* The one small, knowing "wink" on this page — a cherry lozenge. */
  .gifts__wink {
    display: block;
    width: 7px;
    height: 7px;
    margin: clamp(2rem, 5vw, 3rem) auto;
    transform: rotate(45deg);
    background: var(--cherry-piping);
  }

  .gifts__note {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.05rem;
    color: var(--text-muted);
  }
</style>
