---
import { type Locale } from '../../lib/i18n';
import { getStrings } from '../../i18n';
import { RSVP, isRsvpOpen } from '../../data/site';
import type { RsvpFieldErrors, SubmittedValues } from '../../lib/rsvp';
import type { Household, RsvpResponse } from '../../lib/db';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Chapter from '../Chapter.astro';
import RsvpForm from '../RsvpForm.astro';

interface Props {
  locale: Locale;
  household?: Household | null;
  response?: RsvpResponse | null;
  submitted?: SubmittedValues;
  errors?: RsvpFieldErrors;
  summary?: string;
}
const { locale, household = null, response = null, submitted, errors = {}, summary } = Astro.props;
const t = getStrings(locale).rsvp;
const open = isRsvpOpen();

const bcp47 = locale === 'es' ? 'es-ES' : 'en-GB';
const deadlineText = new Intl.DateTimeFormat(bcp47, {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(new Date(`${RSVP.deadline}T12:00:00`));
const deadlineNote = t.deadlineNote.replace('{date}', deadlineText);

const heading = household ? t.title : t.noCodeTitle;
---

<BaseLayout locale={locale} path="/rsvp" title={heading}>
  <Chapter label={t.label} title={heading} headingLevel="h1" id="rsvp">
    {
      !household ? (
        <div class="reveal rsvp__nocode">
          <p class="lead measure">{t.noCodeBody}</p>
        </div>
      ) : !open ? (
        <div class="reveal rsvp__closed">
          <h2 class="rsvp__closed-title">{t.closedTitle}</h2>
          <p class="lead measure">{t.closedBody}</p>
        </div>
      ) : (
        <>
          <p class="lead measure reveal rsvp__intro">{t.intro}</p>
          <p class="muted reveal rsvp__deadline">{deadlineNote}</p>
          {response && <p class="reveal rsvp__edit">{t.editNote}</p>}
          <div class="reveal">
            <RsvpForm
              locale={locale}
              code={household.code}
              invitedGuests={household.invitedGuests}
              plusOnes={household.plusOnes}
              defaultEmail={household.email ?? ''}
              response={response}
              submitted={submitted}
              errors={errors}
              summary={summary}
            />
          </div>
          <div class="rsvp__success" data-rsvp-success tabindex="-1" hidden>
            <h2 class="rsvp__success-title">{t.successTitle}</h2>
            <p class="rsvp__success-review">{t.successReview}</p>
            <div class="rsvp__review" data-success-review></div>
            <p class="rsvp__success-remedy">
              <span class="rsvp__remedy-hint">{t.successChangeHint}</span>
              <button type="button" class="rsvp__change" data-change-answer>{t.successChange}</button>
            </p>
            <p class="rsvp__success-body">{t.successBody}</p>
          </div>
        </>
      )
    }
  </Chapter>
</BaseLayout>

<style>
  .rsvp__intro {
    margin-bottom: 0.65rem;
  }
  .rsvp__deadline {
    margin-bottom: 0.25rem;
    font-style: italic;
  }
  .rsvp__edit {
    margin: 0.75rem 0 0;
    padding: 0.6rem 0.9rem;
    font-size: 0.92rem;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, transparent);
    border-left: 2px solid var(--accent);
    max-width: 46ch;
  }
  .rsvp__success {
    max-width: 40rem;
    margin-top: clamp(1.5rem, 4vw, 2.25rem);
    padding: clamp(1.5rem, 4vw, 2.25rem);
    border: 1px solid color-mix(in srgb, var(--oxidised-bronze) 45%, transparent);
    border-radius: var(--radius);
    background: var(--bg-alt);
  }
  .rsvp__success:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 4px;
  }
  .rsvp__success-title {
    font-size: clamp(1.4rem, 3vw, 1.85rem);
    color: var(--accent);
    margin-bottom: 0.6rem;
  }
  .rsvp__success-review {
    margin: 0 0 0.4rem;
    font-weight: 500;
  }
  .rsvp__review {
    margin: 0.25rem 0 0;
  }
  :global(.rsvp__rlist) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.35rem;
  }
  :global(.rsvp__rlist li) {
    position: relative;
    padding-left: 1.3rem;
  }
  :global(.rsvp__rlist li)::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 600;
  }
  :global(.rsvp__rname) {
    font-weight: 500;
  }
  :global(.rsvp__nomeal) {
    color: var(--text-muted);
    font-style: italic;
  }
  :global(.rsvp__rnot) {
    margin: 0.65rem 0 0;
    color: var(--text-muted);
  }
  :global(.rsvp__decline) {
    margin: 0;
  }
  .rsvp__success-remedy {
    margin: 1.15rem 0 0;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .rsvp__remedy-hint {
    color: var(--text-muted);
    font-size: 0.92rem;
  }
  .rsvp__change {
    font-family: var(--font-body);
    font-size: 0.9rem;
    padding: 0.45rem 0.95rem;
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    cursor: pointer;
    transition: background-color 0.25s var(--ease-soft);
  }
  .rsvp__change:hover {
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }
  .rsvp__success-body {
    max-width: 48ch;
    margin: 1.15rem 0 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .rsvp__closed-title {
    margin-bottom: 0.75rem;
  }
</style>
