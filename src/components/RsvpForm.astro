---
import { actions } from 'astro:actions';
import { getStrings } from '../i18n';
import { type Locale } from '../lib/i18n';
import type { RsvpFieldErrors, SubmittedValues } from '../lib/rsvp';
import type { RsvpResponse } from '../lib/db';
import { MEALS, MEALS_ENABLED } from '../data/site';
import Button from './Button.astro';

interface Props {
  locale: Locale;
  code: string;
  invitedGuests: string[];
  plusOnes: number;
  defaultEmail: string;
  response?: RsvpResponse | null;
  submitted?: SubmittedValues;
  errors?: RsvpFieldErrors;
  summary?: string;
}
const {
  locale,
  code,
  invitedGuests,
  plusOnes,
  defaultEmail,
  response = null,
  submitted,
  errors = {},
  summary,
} = Astro.props;
const t = getStrings(locale).rsvp;

const sitekey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY || '';
const dby = (id: string, hasErr: boolean) => (hasErr ? `${id}-hint ${id}-error` : `${id}-hint`);

// Pre-fill order: what the guest just typed (no-JS error re-render) > a prior
// reply (edit mode) > the defaults.
const emailValue = submitted?.email || response?.email || defaultEmail;
const messageValue = submitted?.message ?? response?.message ?? '';
const dietaryValue = submitted?.dietary ?? response?.dietary ?? '';
const attendingChoice = submitted?.attending ?? response?.attending;
const attendingYes = attendingChoice === 'yes';
const attendingNo = attendingChoice === 'no';

const showMeals = MEALS_ENABLED;
const N = invitedGuests.length;
// A single invited guest needs no per-person toggle — they're coming if the
// household is. With two or more, each gets a Coming / Can't-come choice.
const perGuestToggle = N > 1;
const roster = response?.roster ?? [];

const comingPrefill = (i: number): boolean => {
  const s = submitted?.coming;
  if (s && i < s.length) return s[i] !== 'no';
  const e = roster[i];
  return e ? e.coming : true; // default to coming
};
// Meals are positional across all seats: invited guests [0..N-1], then plus-ones.
const mealPrefillAt = (seat: number): string => {
  const s = submitted?.meals;
  if (s && seat < s.length) return s[seat] ?? '';
  return roster[seat]?.meal ?? '';
};
const plusNamePrefill = (j: number): string => {
  const s = submitted?.plusName;
  if (s && j < s.length) return s[j] ?? '';
  return roster[N + j]?.name ?? '';
};
const plusSlots = Array.from({ length: Math.max(plusOnes, 0) }, (_, j) => j);
---

<form
  class="rsvp"
  method="POST"
  action={actions.rsvp}
  data-rsvp
  data-err-summary={t.errorSummary}
  data-err-email={t.errorEmail}
  data-err-attending={t.errorAttending}
  data-err-closed={t.closedBody}
  data-err-submit={t.submitError}
  data-label-submit={t.submit}
  data-label-submitting={t.submitting}
>
  <div class="rsvp__summary" role="alert" data-error-summary hidden={!summary}>{summary}</div>

  {/* Honeypot: hidden from people and assistive tech; bots fill it. */}
  <div class="rsvp__hp" aria-hidden="true">
    <label for="rsvp-website">Leave this field blank</label>
    <input id="rsvp-website" type="text" name="website" tabindex="-1" autocomplete="off" />
  </div>

  <input type="hidden" name="code" value={code} />
  <input type="hidden" name="_t" value="" data-rendered-at />

  {/* Attending */}
  <fieldset class="field" aria-describedby={errors.attending ? 'rsvp-attending-error' : undefined}>
    <legend>{t.attendingLegend} <span class="req">{t.required}</span></legend>
    <div class="radios">
      <label class="radio">
        <input type="radio" name="attending" value="yes" required checked={attendingYes} />
        <span>{t.attendingYes}</span>
      </label>
      <label class="radio">
        <input type="radio" name="attending" value="no" checked={attendingNo} />
        <span>{t.attendingNo}</span>
      </label>
    </div>
    <p class="field__error" id="rsvp-attending-error" data-error="attending" hidden={!errors.attending}>
      {errors.attending}
    </p>
  </fieldset>

  {/* Who's coming + meals — your named guests (fixed), then any granted plus-one. */}
  <div class="field" data-when-yes>
    <span class="field__grouplabel">{t.mealsLabel}</span>
    <p class="field__hint">{t.mealsHint}</p>
    <div class="guests">
      {
        invitedGuests.map((name, i) => (
          <div class="guest" data-guest-row>
            <span class="guest__name">{name}</span>
            <div class="guest__controls">
              {perGuestToggle && (
                <select class="guest__coming" name="coming" aria-label={`${name} — ${t.comingLabel}`}>
                  <option value="yes" selected={comingPrefill(i)}>
                    {t.comingYes}
                  </option>
                  <option value="no" selected={!comingPrefill(i)}>
                    {t.comingNo}
                  </option>
                </select>
              )}
              {showMeals && (
                <select class="guest__meal" name="meals" data-meal aria-label={`${name} — ${t.mealsLabel}`}>
                  <option value="">{t.mealChoose}</option>
                  {MEALS.map((m) => (
                    <option value={m.id} selected={mealPrefillAt(i) === m.id}>
                      {locale === 'es' ? m.es : m.en}
                    </option>
                  ))}
                </select>
              )}
            </div>
          </div>
        ))
      }
      {
        plusSlots.map((j) => (
          <div class="guest guest--plus" data-guest-row data-plus>
            <input
              type="text"
              name="plusName"
              class="guest__plusname"
              placeholder={t.plusOneName}
              value={plusNamePrefill(j)}
              maxlength="120"
              autocomplete="off"
              aria-label={t.plusOneName}
            />
            <div class="guest__controls">
              {showMeals && (
                <select class="guest__meal" name="meals" data-meal aria-label={`${t.plusOneName} — ${t.mealsLabel}`}>
                  <option value="">{t.mealChoose}</option>
                  {MEALS.map((m) => (
                    <option value={m.id} selected={mealPrefillAt(N + j) === m.id}>
                      {locale === 'es' ? m.es : m.en}
                    </option>
                  ))}
                </select>
              )}
            </div>
          </div>
        ))
      }
    </div>
    {plusOnes > 0 && <p class="field__hint guests__note">{t.plusOneNote}</p>}
  </div>

  {/* Email */}
  <div class="field">
    <label for="rsvp-email">{t.emailLabel} <span class="req">{t.required}</span></label>
    <p class="field__hint" id="rsvp-email-hint">{t.emailHint}</p>
    <input
      id="rsvp-email"
      name="email"
      type="email"
      required
      maxlength="200"
      autocomplete="email"
      inputmode="email"
      value={emailValue}
      aria-describedby={dby('rsvp-email', Boolean(errors.email))}
      aria-invalid={errors.email ? 'true' : undefined}
    />
    <p class="field__error" id="rsvp-email-error" data-error="email" hidden={!errors.email}>
      {errors.email}
    </p>
  </div>

  {/* Dietary — only relevant when attending; JS hides it on "no". */}
  <div class="field" data-when-yes>
    <label for="rsvp-dietary">{t.dietaryLabel} <span class="opt">{t.optional}</span></label>
    <p class="field__hint" id="rsvp-dietary-hint">{t.dietaryHint}</p>
    <textarea id="rsvp-dietary" name="dietary" rows="2" maxlength="1000" aria-describedby="rsvp-dietary-hint"
      >{dietaryValue}</textarea
    >
  </div>

  {/* Message */}
  <div class="field">
    <label for="rsvp-message">{t.messageLabel} <span class="opt">{t.optional}</span></label>
    <p class="field__hint" id="rsvp-message-hint">{t.messageHint}</p>
    <textarea id="rsvp-message" name="message" rows="3" maxlength="2000" aria-describedby="rsvp-message-hint"
      >{messageValue}</textarea
    >
  </div>

  {
    sitekey && (
      <div class="field rsvp__turnstile">
        <div class="cf-turnstile" data-sitekey={sitekey} data-theme="light" data-language={locale} />
      </div>
    )
  }

  <p class="rsvp__consent">{t.consentNote}</p>

  <div class="rsvp__actions">
    <Button variant="primary" class="rsvp__submit">{t.submit}</Button>
  </div>

  <noscript>
    <p class="field__hint rsvp__noscript">{t.noscriptNote}</p>
  </noscript>
</form>

{
  sitekey && (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer />
  )
}

<script>
  import { actions, isInputError } from 'astro:actions';

  const form = document.querySelector<HTMLFormElement>('[data-rsvp]');
  if (form) {
    const d = form.dataset;
    const labels = {
      summary: d.errSummary || '',
      submit: d.labelSubmit || 'Send',
      submitting: d.labelSubmitting || '…',
      closed: d.errClosed || '',
      submitError: d.errSubmit || '',
      fields: {
        email: d.errEmail || '',
        attending: d.errAttending || '',
      } as Record<string, string>,
    };

    const summaryEl = form.querySelector<HTMLElement>('[data-error-summary]');
    const submitBtn = form.querySelector<HTMLButtonElement>('.rsvp__submit');
    const submitLabel = submitBtn?.querySelector<HTMLElement>('.btn__label') ?? submitBtn;

    const stamp = form.querySelector<HTMLInputElement>('[data-rendered-at]');
    if (stamp) stamp.value = String(Date.now());

    // Reveal the attending-only sections (guests, dietary) on "yes".
    const conditional = Array.from(form.querySelectorAll<HTMLElement>('[data-when-yes]'));
    const radios = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="attending"]'));
    const syncConditional = () => {
      const chosen = radios.find((r) => r.checked);
      const show = !chosen || chosen.value === 'yes';
      conditional.forEach((el) => (el.hidden = !show));
    };
    radios.forEach((r) => r.addEventListener('change', syncConditional));
    syncConditional();

    // Per guest: show the meal selector only when that person is actually coming
    // (or, for a plus-one, only once a name is typed).
    const guestRows = Array.from(form.querySelectorAll<HTMLElement>('[data-guest-row]'));
    const syncGuestRow = (row: HTMLElement) => {
      const meal = row.querySelector<HTMLElement>('[data-meal]');
      if (!meal) return;
      const coming = row.querySelector<HTMLSelectElement>('select[name="coming"]');
      const plusname = row.querySelector<HTMLInputElement>('input[name="plusName"]');
      let show = true;
      if (coming) show = coming.value !== 'no';
      else if (plusname) show = plusname.value.trim() !== '';
      meal.hidden = !show;
    };
    guestRows.forEach((row) => {
      row
        .querySelector<HTMLSelectElement>('select[name="coming"]')
        ?.addEventListener('change', () => syncGuestRow(row));
      row
        .querySelector<HTMLInputElement>('input[name="plusName"]')
        ?.addEventListener('input', () => syncGuestRow(row));
      syncGuestRow(row);
    });

    const ERROR_FIELDS = ['attending', 'email'] as const;
    const fieldError = (name: string) => form.querySelector<HTMLElement>(`[data-error="${name}"]`);
    const fieldInput = (name: string) =>
      form.querySelector<HTMLInputElement | HTMLSelectElement>(`[name="${name}"]`);

    const applyErrorAria = (name: string, on: boolean) => {
      const err = fieldError(name);
      if (!err) return;
      const hintId = err.id.replace(/-error$/, '-hint');
      const hasHint = Boolean(document.getElementById(hintId));
      const isGroup = name === 'attending';
      const target: HTMLElement | null = isGroup ? err.closest('fieldset') : fieldInput(name);
      if (!target) return;
      if (on) {
        target.setAttribute(
          'aria-describedby',
          [hasHint ? hintId : '', err.id].filter(Boolean).join(' '),
        );
        if (!isGroup) target.setAttribute('aria-invalid', 'true');
      } else {
        if (hasHint) target.setAttribute('aria-describedby', hintId);
        else target.removeAttribute('aria-describedby');
        target.removeAttribute('aria-invalid');
      }
    };

    const clearErrors = () => {
      if (summaryEl) {
        summaryEl.hidden = true;
        summaryEl.textContent = '';
      }
      ERROR_FIELDS.forEach((name) => {
        const err = fieldError(name);
        if (err) {
          err.hidden = true;
          err.textContent = '';
        }
        applyErrorAria(name, false);
      });
    };

    const showFieldError = (name: string, message: string) => {
      const err = fieldError(name);
      if (err) {
        err.textContent = message;
        err.hidden = false;
      }
      applyErrorAria(name, true);
    };

    const showSummary = (message: string) => {
      if (summaryEl) {
        summaryEl.textContent = message;
        summaryEl.hidden = false;
      }
    };

    const setBusy = (busy: boolean) => {
      if (!submitBtn) return;
      submitBtn.disabled = busy;
      if (busy) submitBtn.setAttribute('aria-busy', 'true');
      else submitBtn.removeAttribute('aria-busy');
      if (submitLabel) submitLabel.textContent = busy ? labels.submitting : labels.submit;
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearErrors();
      setBusy(true);

      const { data, error } = await actions.rsvp(new FormData(form));

      if (!error && data?.ok) {
        const success = document.querySelector<HTMLElement>('[data-rsvp-success]');
        form.hidden = true;
        if (success) {
          success.hidden = false;
          success.focus();
          success.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        return;
      }

      setBusy(false);
      (window as unknown as { turnstile?: { reset?: () => void } }).turnstile?.reset?.();

      if (error && isInputError(error)) {
        const fields = error.fields as Record<string, string[] | undefined>;
        let firstInvalid: string | null = null;
        ERROR_FIELDS.forEach((name) => {
          if (fields[name]) {
            showFieldError(name, labels.fields[name]);
            if (!firstInvalid) firstInvalid = name;
          }
        });
        showSummary(labels.summary);
        if (firstInvalid) fieldInput(firstInvalid)?.focus();
        else summaryEl?.focus();
      } else {
        // Non-field error: closed deadline, or spam/captcha/server issue.
        const code = (error as { code?: string } | null)?.code;
        showSummary(code === 'FORBIDDEN' ? labels.closed : labels.submitError);
        summaryEl?.focus();
      }
    });
  }
</script>

<style>
  .rsvp {
    max-width: 34rem;
    margin-top: clamp(1.25rem, 3vw, 1.75rem);
  }

  .field {
    margin: 0 0 clamp(1.25rem, 3.5vw, 1.85rem);
    border: 0;
    padding: 0;
    min-inline-size: 0;
  }

  label,
  legend {
    display: block;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text-display);
    padding: 0;
  }

  .req,
  .opt {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-inline-start: 0.4rem;
    vertical-align: 0.08em;
  }

  .field__hint {
    margin: 0.3rem 0 0.6rem;
    font-size: 0.88rem;
    color: var(--text-muted);
    max-width: 46ch;
  }

  input[type='text'],
  input[type='email'],
  select,
  textarea {
    display: block;
    width: 100%;
    padding: 0.7rem 0.85rem;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text);
    background: color-mix(in srgb, var(--candle-ivory) 55%, var(--old-parchment));
    border: 1px solid var(--rule-strong);
    border-radius: var(--radius);
    transition: border-color 0.25s var(--ease-soft), box-shadow 0.25s var(--ease-soft);
  }
  select {
    max-width: 8rem;
  }
  textarea {
    resize: vertical;
    min-height: 3rem;
  }
  input:focus-visible,
  select:focus-visible,
  textarea:focus-visible {
    border-color: var(--accent);
  }
  input[aria-invalid='true'],
  select[aria-invalid='true'],
  textarea[aria-invalid='true'] {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
  }

  .radios {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.5rem;
    margin-top: 0.65rem;
  }
  .radio {
    display: inline-flex;
    align-items: baseline;
    gap: 0.55rem;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 430;
    color: var(--text);
    cursor: pointer;
  }
  .radio input {
    accent-color: var(--accent);
    width: 1.05rem;
    height: 1.05rem;
    flex: none;
    translate: 0 0.15rem;
  }

  .field__error {
    margin: 0.5rem 0 0;
    font-size: 0.9rem;
    color: var(--accent);
  }

  .field__grouplabel {
    display: block;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text-display);
  }

  /* Per-guest rows: a fixed name (or a plus-one's editable name) followed by a
     grouped control set (coming + meal). The controls stay together as one unit,
     so on a narrow screen they wrap beneath the name rather than the meal drifting
     onto its own line where it could be misread against the wrong person. */
  .guests {
    display: grid;
    gap: 0.85rem;
    margin-top: 0.55rem;
  }
  .guest {
    display: flex;
    align-items: center;
    gap: 0.35rem 0.7rem;
    flex-wrap: wrap;
  }
  .guest__name {
    flex: 0 1 auto;
    min-width: 6rem;
    font-size: 1rem;
    font-weight: 460;
    color: var(--text);
  }
  /* The control set never splits internally: coming + meal stay side by side as
     one unit, so the meal can't strand on its own line away from its guest. */
  .guest__controls {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.5rem;
    flex: 1 1 auto;
    min-width: 0;
  }
  .guest__coming {
    flex: 0 0 7.5rem;
    min-width: 0;
    max-width: none;
  }
  .guest__meal {
    flex: 1 1 auto;
    min-width: 0;
    max-width: none;
  }
  .guest__meal[hidden] {
    display: none;
  }
  .guest__plusname {
    flex: 1 1 8rem;
    min-width: 0;
    max-width: none;
  }
  .guest--plus {
    margin-top: 0.15rem;
    padding-top: 0.6rem;
    border-top: 1px dashed var(--rule);
  }
  .guests__note {
    margin-top: 0.65rem;
  }
  /* Narrow screens: the whole control set drops beneath the name as one block,
     keeping each person's name, attendance, and meal unmistakably together. */
  @media (max-width: 33rem) {
    .guest__name,
    .guest__controls {
      flex-basis: 100%;
    }
  }

  .rsvp__summary {
    margin-bottom: clamp(1.25rem, 3vw, 1.75rem);
    padding: 0.85rem 1.05rem;
    font-size: 0.95rem;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 7%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    border-radius: var(--radius);
  }
  .rsvp__summary[hidden] {
    display: none;
  }

  .rsvp__turnstile {
    min-height: 65px;
  }

  .rsvp__consent {
    margin: 0 0 1rem;
    font-size: 0.82rem;
    color: var(--text-muted);
    max-width: 52ch;
  }

  .rsvp__actions {
    margin-top: clamp(1.25rem, 3vw, 1.5rem);
  }

  .rsvp__noscript {
    margin-top: 1rem;
  }

  /* Honeypot — present in the DOM, invisible to people and assistive tech. */
  .rsvp__hp {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }
</style>
