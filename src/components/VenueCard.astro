---
import type { Venue } from '../data/site';
import { googleDirections, appleMaps, what3wordsUrl } from '../lib/maps';
import ImagePlaceholder from './ImagePlaceholder.astro';
import Frame from './Frame.astro';
import Button from './Button.astro';

interface Props {
  venue: Venue;
  roleLabel: string;
  blurb: string;
  arrival: string;
  parking: string;
  addressLabel: string;
  arrivalLabel: string;
  parkingLabel: string;
  ui: { directions: string; appleMaps: string; what3words: string };
  plate: string;
}
const {
  venue,
  roleLabel,
  blurb,
  arrival,
  parking,
  addressLabel,
  arrivalLabel,
  parkingLabel,
  ui,
  plate,
} = Astro.props;

const dest = `${venue.name}, ${venue.postcode}`;
---

<article class="venue reveal">
  <div class="venue__media">
    {
      venue.image ? (
        <Frame
          src={venue.image.src}
          alt={venue.image.alt}
          width={venue.image.width}
          height={venue.image.height}
          ratio="3 / 2"
        />
      ) : (
        <ImagePlaceholder ratio="3 / 2" label={`${venue.name} — ${plate}`} plate="I" />
      )
    }
  </div>

  <header class="venue__head">
    <div class="venue__title">
      <p class="chapter-label">{roleLabel}</p>
      <h3 class="venue__name">{venue.name}</h3>
    </div>
    <p class="venue__blurb">{blurb}</p>
  </header>

  <dl class="venue__facts">
    <div class="venue__fact">
      <dt>{addressLabel}</dt>
      <dd>
        {venue.addressLines.map((line) => <span class="venue__addr-line">{line}</span>)}
        <span class="venue__addr-line">{venue.postcode}</span>
      </dd>
    </div>
    <div class="venue__fact">
      <dt>{arrivalLabel}</dt>
      <dd>{arrival}</dd>
    </div>
    <div class="venue__fact">
      <dt>{parkingLabel}</dt>
      <dd>{parking}</dd>
    </div>
  </dl>

  <div class="venue__actions">
    <Button href={googleDirections(dest)} external variant="primary">{ui.directions}</Button>
    <Button href={appleMaps(dest)} external variant="quiet">{ui.appleMaps}</Button>
    {
      venue.what3words && (
        <a class="w3w" href={what3wordsUrl(venue.what3words)} target="_blank" rel="noopener noreferrer">
          <span class="w3w__label">{ui.what3words}</span>
          <span class="w3w__addr">
            <span class="w3w__slashes" aria-hidden="true">///</span>
            {venue.what3words}
          </span>
        </a>
      )
    }
  </div>
</article>

<style>
  .venue {
    display: grid;
    gap: clamp(1.25rem, 4vw, 1.75rem);
  }

  .venue__name {
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    margin-top: 0.4rem;
  }
  .venue__blurb {
    margin-top: 0.9rem;
    max-width: 46ch;
  }

  .venue__facts {
    margin: 0;
    display: grid;
    gap: 0.9rem;
  }
  .venue__fact {
    display: grid;
    gap: 0.2rem;
  }
  .venue__fact dt {
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--oxidised-bronze);
  }
  .venue__fact dd {
    margin: 0;
    font-size: 1rem;
    color: var(--text);
    max-width: 38ch;
  }
  .venue__addr-line {
    display: block;
  }

  .venue__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.75rem;
  }

  .w3w {
    display: inline-flex;
    flex-direction: column;
    gap: 0.15rem;
    text-decoration: none;
    color: var(--text);
    width: fit-content;
  }
  .w3w__label {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .w3w__addr {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 450;
  }
  .w3w__slashes {
    color: var(--oxblood);
    font-weight: 600;
    margin-right: 0.1em;
  }
  .w3w:hover .w3w__addr {
    color: var(--accent);
  }

  /* ---- Desktop: banner on top, editorial dossier below ---- */
  @media (min-width: 48rem) {
    .venue {
      grid-template-columns: 1fr 1fr;
      column-gap: clamp(2rem, 5vw, 4rem);
      row-gap: clamp(1.75rem, 3.5vw, 2.75rem);
      grid-template-areas:
        'head head'
        'media media'
        'facts facts'
        'actions actions';
      align-items: end;
    }
    .venue__head {
      grid-area: head;
      display: grid;
      grid-template-columns: 1fr 1fr;
      column-gap: clamp(2rem, 5vw, 4rem);
      align-items: end;
    }
    .venue__name {
      margin-top: 0.5rem;
    }
    .venue__blurb {
      margin-top: 0;
      max-width: 40ch;
    }

    .venue__media {
      grid-area: media;
    }
    /* widen to a banner so the landscape photo sits proud, not squeezed */
    .venue__media :global(.frame) {
      aspect-ratio: 16 / 7;
    }

    .venue__facts {
      grid-area: facts;
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(1.5rem, 3vw, 2.75rem);
      padding-top: clamp(1.25rem, 2.5vw, 1.75rem);
      border-top: 1px solid var(--rule);
    }
    .venue__fact dd {
      font-size: 1.02rem;
    }

    .venue__actions {
      grid-area: actions;
      gap: 1.25rem 2rem;
    }
  }
</style>
