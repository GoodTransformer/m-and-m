---
import type { Venue } from '../data/site';
import { googleDirections, appleMaps, what3wordsUrl } from '../lib/maps';
import ImagePlaceholder from './ImagePlaceholder.astro';
import Frame from './Frame.astro';
import Button from './Button.astro';
import { venueImages } from '../assets/images';

interface Props {
  venue: Venue;
  roleLabel: string;
  blurb: string;
  arrival: string;
  parking: string;
  addressLabel: string;
  arrivalLabel: string;
  parkingLabel: string;
  ui: { directions: string; appleMaps: string; what3words: string };
  plate: string;
  flip?: boolean;
}
const {
  venue,
  roleLabel,
  blurb,
  arrival,
  parking,
  addressLabel,
  arrivalLabel,
  parkingLabel,
  ui,
  plate,
  flip = false,
} = Astro.props;

const dest = `${venue.name}, ${venue.postcode}`;
---

<article class:list={['venue', flip && 'venue--flip', 'reveal']}>
  <div class="venue__media">
    {
      venueImages[venue.id] ? (
        <Frame
          src={venueImages[venue.id]}
          alt={venue.image?.alt ?? venue.name}
          ratio="4 / 5"
          width={940}
        />
      ) : (
        <ImagePlaceholder ratio="4 / 5" label={`${venue.name} — ${plate}`} plate="I" />
      )
    }
  </div>

  <div class="venue__body">
    <p class="chapter-label">{roleLabel}</p>
    <h3 class="venue__name">{venue.name}</h3>
    <p class="venue__blurb">{blurb}</p>

    <dl class="venue__facts">
      <div class="venue__fact">
        <dt>{addressLabel}</dt>
        <dd>
          {venue.addressLines.map((line) => <span class="venue__addr-line">{line}</span>)}
          <span class="venue__addr-line">{venue.postcode}</span>
        </dd>
      </div>
      <div class="venue__fact">
        <dt>{arrivalLabel}</dt>
        <dd>{arrival}</dd>
      </div>
      <div class="venue__fact">
        <dt>{parkingLabel}</dt>
        <dd>{parking}</dd>
      </div>
    </dl>

    <div class="venue__actions">
      <Button href={googleDirections(dest)} external variant="primary">{ui.directions}</Button>
      <Button href={appleMaps(dest)} external variant="quiet">{ui.appleMaps}</Button>
    </div>

    {
      venue.what3words && (
        <a class="w3w" href={what3wordsUrl(venue.what3words)} target="_blank" rel="noopener noreferrer">
          <span class="w3w__label">{ui.what3words}</span>
          <span class="w3w__addr">
            <span class="w3w__slashes" aria-hidden="true">///</span>
            {venue.what3words}
          </span>
        </a>
      )
    }
  </div>
</article>

<style>
  .venue {
    display: grid;
    gap: clamp(1.5rem, 5vw, 2rem);
  }

  .venue__media {
    max-width: 24rem;
    margin-inline: auto;
    width: 100%;
  }

  .venue__name {
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    margin-top: 0.5rem;
  }
  .venue__blurb {
    margin-top: 0.9rem;
    max-width: 42ch;
  }

  .venue__facts {
    margin: clamp(1.25rem, 3vw, 1.75rem) 0 0;
    display: grid;
    gap: 0.9rem;
  }
  .venue__fact {
    display: grid;
    gap: 0.2rem;
  }
  .venue__fact dt {
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--oxidised-bronze);
  }
  .venue__fact dd {
    margin: 0;
    font-size: 1rem;
    color: var(--text);
    max-width: 40ch;
  }
  .venue__addr-line {
    display: block;
  }

  .venue__actions {
    margin-top: clamp(1.25rem, 3vw, 1.75rem);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
  }

  .w3w {
    margin-top: 1.1rem;
    display: inline-flex;
    flex-direction: column;
    gap: 0.15rem;
    text-decoration: none;
    color: var(--text);
    width: fit-content;
  }
  .w3w__label {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .w3w__addr {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 450;
  }
  .w3w__slashes {
    color: var(--oxblood);
    font-weight: 600;
    margin-right: 0.1em;
  }
  .w3w:hover .w3w__addr {
    color: var(--accent);
  }

  /* ---- Desktop: image beside text (portrait), alternating sides ---- */
  @media (min-width: 48rem) {
    .venue {
      grid-template-columns: 0.82fr 1fr;
      align-items: center;
      gap: clamp(2.5rem, 5vw, 4.5rem);
    }
    .venue__media {
      max-width: none;
      margin-inline: 0;
    }
    .venue--flip .venue__media {
      order: 2;
    }
  }
</style>
