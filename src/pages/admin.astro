---
export const prerender = false;
import { listHouseholdsWithResponses, type HouseholdWithResponse } from '../lib/db';
import { householdLink, siteOriginLooksUnset } from '../lib/links';
import { MEALS, MEALS_ENABLED, rosterLines, notComingNames, RSVP, isRsvpOpen } from '../data/site';
import '../styles/tokens.css';

const households = await listHouseholdsWithResponses();
const responded = households.filter((h) => h.response);
const attending = responded.filter((h) => h.response!.attending === 'yes');
const headcount = attending.reduce((n, h) => n + h.response!.partySize, 0);
const declined = responded.filter((h) => h.response!.attending === 'no').length;
// Exclude already-replied households so this matches householdsPendingInvite()
// (which won't re-invite a responder) — the panel must not promise more than a send.
const pendingInvite = households.filter(
  (h) => h.inviteStatus !== 'sent' && h.email && !h.response,
).length;
const outstanding = households.filter((h) => h.inviteStatus === 'sent' && !h.response).length;
// How many of those would actually be reminded right now: invitedNonResponders
// skips anyone reminded in the last 12h, so the panel must not promise more.
const TWELVE_H_MS = 12 * 60 * 60 * 1000;
const nowMs = Date.now();
const remindable = households.filter(
  (h) =>
    h.inviteStatus === 'sent' &&
    !h.response &&
    h.email &&
    (!h.remindedAt || nowMs - Date.parse(`${h.remindedAt.replace(' ', 'T')}Z`) >= TWELVE_H_MS),
).length;
const dietaryCount = attending.filter((h) => h.response!.dietary.trim()).length;

// Meal tally for the caterer + count of households where a coming guest has no meal.
const mealTally = MEALS.map((m) => ({
  label: m.en,
  count: attending.reduce(
    (n, h) => n + h.response!.roster.filter((r) => r.coming && r.meal === m.id).length,
    0,
  ),
}));
const missingMeals = attending.filter((h) =>
  h.response!.roster.some((r) => r.coming && !r.meal),
).length;

// Safety net: warn if the live origin looks unset, which would bake broken
// personal links into every invitation (only flags in production).
const linkWarning = import.meta.env.PROD && siteOriginLooksUnset();
// Warn (in production) if email sending isn't configured — guests would get no
// confirmation and invitations/reminders can't go out.
const emailWarning = import.meta.env.PROD && !import.meta.env.RESEND_API_KEY;

// Headcount + replied live in the headline line, so the tiles cover the rest.
const stats: Array<[number, string]> = [
  [attending.length, 'parties coming'],
  [declined, 'unable to come'],
  [outstanding, 'awaiting reply'],
  [dietaryCount, 'dietary notes'],
];
if (MEALS_ENABLED) stats.push([missingMeals, 'missing a meal']);

function statusLabel(s: string): string {
  return s === 'sent' ? 'invited' : s;
}

function isMissingMeals(h: HouseholdWithResponse): boolean {
  return Boolean(
    MEALS_ENABLED &&
      h.response &&
      h.response.attending === 'yes' &&
      h.response.roster.some((r) => r.coming && !r.meal),
  );
}

// A reply is "stale" if the household's named people or plus-one allowance were
// changed (e.g. a later re-import) AFTER the guest replied, so their saved roster
// no longer matches the current guest list. Recomputed every render, so the flag
// persists in the dashboard until the reply is re-checked. Only meaningful for a
// "yes" reply (a decline stores no roster).
function replyIsStale(h: HouseholdWithResponse): boolean {
  const r = h.response;
  if (!r || r.attending !== 'yes') return false;
  const rosterInvited = r.roster.filter((e) => !e.plusOne).map((e) => e.name);
  const rosterPlus = r.roster.filter((e) => e.plusOne).length;
  return (
    JSON.stringify(rosterInvited) !== JSON.stringify(h.invitedGuests) || rosterPlus !== h.plusOnes
  );
}

// ---------------------------------------------------------------------------
// Guided, step-by-step workflow state. The dashboard is laid out as numbered
// steps in the order the couple actually work; these values decide what's done,
// what's the current thing to do, and the one-line "what's next" banner.
// ---------------------------------------------------------------------------
const hasList = households.length > 0;
const someInvited = households.some((h) => h.inviteStatus === 'sent');
const guestCount = households.reduce((n, h) => n + h.invitedGuests.length + h.plusOnes, 0);
// "Paper guests" have no email: they can't be auto-invited or reminded (every send
// filters on email), so the couple hand them their link themselves. They'd vanish
// from every count otherwise — track them, and never say "everyone replied" while
// one is still outstanding.
const paperGuests = households.filter((h) => !h.email);
const paperOutstanding = paperGuests.filter((h) => !h.response).length;
const allReplied =
  hasList && outstanding === 0 && pendingInvite === 0 && paperOutstanding === 0;

// Days until the RSVP deadline, from the SAME Anywhere-on-Earth boundary as
// isRsvpOpen() so the countdown and the open/closed copy can never disagree.
const rsvpOpen = isRsvpOpen();
const deadlineMs = Date.parse(`${RSVP.deadline}T23:59:59-12:00`);
const daysUntilDeadline = Number.isNaN(deadlineMs)
  ? null
  : Math.ceil((deadlineMs - Date.now()) / 86_400_000);

// Allergy / dietary lines for the caterer step.
const dietaryNotes = attending
  .filter((h) => h.response!.dietary.trim())
  .map((h) => ({ label: h.label, dietary: h.response!.dietary.trim() }));

type StepState = 'now' | 'done' | 'later' | 'waiting' | 'ready';
const step1: StepState = hasList ? 'done' : 'now'; // 1 · Add the guest list
const step2: StepState = !hasList ? 'later' : pendingInvite > 0 ? 'now' : 'done'; // 2 · Send invitations
const step3: StepState = hasList ? 'ready' : 'later'; // 3 · Track the replies
const step4: StepState = !someInvited // 4 · Send a reminder
  ? 'later'
  : outstanding === 0
    ? 'done'
    : remindable > 0
      ? 'now'
      : 'waiting';
const step5: StepState = // 5 · Give the caterer the numbers
  !rsvpOpen || allReplied || (daysUntilDeadline !== null && daysUntilDeadline <= 7)
    ? 'now'
    : 'ready';

function stepPill(s: StepState): string {
  if (s === 'now') return '👈 Do this now';
  if (s === 'done') return '✓ Done';
  if (s === 'waiting') return 'In cooldown';
  if (s === 'ready') return 'Anytime';
  return 'Later';
}

// The single most important line on the page: what to do next.
const bannerText = !hasList
  ? '👉 Start here — paste your guest list into Step 1 below.'
  : !rsvpOpen
    ? '⏰ The RSVP deadline has passed. The final numbers are ready for your caterer in Step 5.'
    : pendingInvite > 0
      ? `👉 Next: send your invitations (Step 2). ${pendingInvite} ready — test to yourselves first.`
      : allReplied
        ? '🎉 Everyone has replied! When you’re ready, send the caterer the numbers (Step 5).'
        : remindable > 0
          ? `👉 Next: ${remindable} ${remindable === 1 ? 'guest hasn’t' : 'guests haven’t'} replied — send a reminder (Step 4).`
          : outstanding > 0
            ? '✓ Reminders are up to date — nothing to do right now. New replies appear in Step 3.'
            : '✓ You’re all set.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>RSVP admin · Mari &amp; Michael</title>
  </head>
  <body>
    <main class="wrap">
      <header class="head">
        <h1>RSVP admin</h1>
        <span class="head__links">
          <a class="link" href="export.csv">Download CSV</a>
          <a class="link" href="/admin/logout/">Sign out</a>
        </span>
      </header>

      {/* The one line that orients everything: what to do next. */}
      <p class="banner">{bannerText}</p>
      <p class="headline">
        {responded.length} of {households.length} replied · {headcount} coming
        {daysUntilDeadline !== null &&
          rsvpOpen &&
          ` · ${daysUntilDeadline} ${daysUntilDeadline === 1 ? 'day' : 'days'} until the RSVP deadline`}
        {daysUntilDeadline !== null && !rsvpOpen && ' · the RSVP deadline has passed'}
      </p>

      {
        linkWarning && (
          <p class="warn">
            ⚠ SITE_URL looks unset — personal links in invitations would be wrong. Set SITE_URL to
            your live origin in Vercel, redeploy, then re-check a link before sending.
          </p>
        )
      }
      {
        emailWarning && (
          <p class="warn">
            ⚠ RESEND_API_KEY looks unset — confirmation emails and invitations/reminders will NOT be
            sent. Add it in Vercel and redeploy before sending anything.
          </p>
        )
      }

      <ul class="stats">
        {
          stats.map(([n, label]) => (
            <li>
              <span class="stat__n">{n}</span>
              <span class="stat__l">{label}</span>
            </li>
          ))
        }
      </ul>

      <ol class="steps">
        {/* ---- Step 1 — Add your guest list ---- */}
        <li class:list={['step', `is-${step1}`]}>
          <div class="step__bar">
            <span class="step__num">1</span>
            <h2 class="step__title">Add your guest list</h2>
            <span class="pill">{step1 === 'done' ? '✓ Done' : 'Start here'}</span>
          </div>
          <p class="step__hint">
            {step1 === 'done' ? (
              <Fragment>
                This is where you add your guest list. You’ll see everyone — and their replies — in
                Step 3. Need to add someone or fix a detail? Open <em>Update the guest list</em> below.
              </Fragment>
            ) : (
              'This is where you add everyone you’re inviting — as a simple spreadsheet. The guide below shows exactly how; paste your list in and press Import. Each household then gets its own private invitation link.'
            )}
          </p>
          <details class="fold" open={step1 !== 'done'}>
            <summary>{step1 === 'done' ? 'Update the guest list' : 'How to add your list'}</summary>
            <p class="muted">
              Make the list in a spreadsheet — Excel, Numbers or Google Sheets — then copy the cells
              and paste them into the box below. (You can also just type the rows straight in.) The
              first row names the columns; every row after it is one household.
            </p>
            <p class="muted">
              Put these columns <strong>in this order</strong> — only the first one is required:
            </p>
            <ol class="cols">
              <li>
                <code>household</code> — what you’ll call them in the invitation, e.g.
                <em>The Whitfields</em> or <em>Tomás Herrera</em>.
              </li>
              <li>
                <code>guests</code> — everyone’s full name, separated by semicolons, like
                <em>Eleanor Whitfield; James Whitfield</em>. Each name becomes one seat.
              </li>
              <li>
                <code>email</code> — where their invitation is sent. Leave it blank for anyone you’ll
                hand the link to in person.
              </li>
              <li>
                <code>plus</code> — any extra, <em>unnamed</em> “+ guest” seats they may bring (a single
                guest’s partner, say). Usually <em>0</em> — you’ve already named everyone you know in
                <code>guests</code>.
              </li>
              <li>
                <code>language</code> — <em>en</em> for English or <em>es</em> for Spanish.
              </li>
            </ol>
            <p class="muted">
              <strong>Names vs. a plus-one.</strong> If you know who’s coming, name everyone in
              <code>guests</code> and leave <code>plus</code> at 0 — that’s true for couples and families
              too. Only use <code>plus</code> for a seat you can’t name yet, like a single guest who may
              bring a partner you haven’t met (one unknown guest → <code>plus</code> 1).
            </p>
            <p class="muted">Here’s what your sheet will look like — the column names along the top, then one row per household:</p>
            <img
              class="example-img"
              src={`${import.meta.env.BASE_URL}guest-list-example.png`}
              width="1440"
              height="720"
              loading="lazy"
              alt="A spreadsheet with the columns household, guests, email, plus, language. The Whitfields: two names separated by a semicolon, plus 0. Lizzie Thornton: one name, plus 1 — she may bring a guest. The Okonkwos: three names. Tomás Herrera: language es. Mary Stevens: no email — a paper guest you invite by hand."
            />
            <p class="muted">
              Pasting an updated list later is safe — it updates people who are already there and
              never makes duplicates.
            </p>
            <p class="muted">
              Now add your list — <strong>upload a <code>.csv</code> file</strong> or <strong>paste the
              rows</strong> below. (To make a CSV from your spreadsheet: <em>File → Save as / Download →
              CSV</em>.)
            </p>
            <div class="upload-row">
              <label class="file-btn">
                Choose a CSV file…
                <input
                  type="file"
                  accept=".csv,.tsv,.txt,text/csv,text/plain,text/tab-separated-values"
                  data-csv-file
                  hidden
                />
              </label>
              <span class="file-name" data-csv-file-name aria-live="polite"></span>
            </div>
            <textarea
              data-csv
              rows="6"
              placeholder="household,guests,email,plus,language&#10;The Whitfields,Eleanor Whitfield; James Whitfield,eleanor@example.com,0,en"
></textarea>
            <div class="btns">
              <button type="button" data-import-preview>Preview</button>
              <button type="button" class="btn-go" data-import-go>Import</button>
            </div>
            <p class="result" data-import-result aria-live="polite"></p>
          </details>
          {step1 === 'done' && (
            <p class="step__count">
              <span class="step__count-label">On the list</span>
              {households.length} households · {guestCount} guests
            </p>
          )}
        </li>

        {/* ---- Step 2 — Send the invitations ---- */}
        <li class:list={['step', `is-${step2}`]}>
          <div class="step__bar">
            <span class="step__num">2</span>
            <h2 class="step__title">Send the invitations</h2>
            <span class="pill">{stepPill(step2)}</span>
          </div>
          {
            step2 === 'later' ? (
              <p class="step__hint">This is where you’ll email everyone their invitation. Add your guest list in Step 1 first, then come back and send them all at once.</p>
            ) : step2 === 'done' ? (
              <p class="step__hint">
                ✓ Everyone with an email has been invited.
                {paperGuests.length > 0 &&
                  ` Hand the ${paperGuests.length} paper guest${paperGuests.length === 1 ? '' : 's'} their link from Step 3.`}
              </p>
            ) : (
              <Fragment>
                <p class="step__hint">
                  This emails everyone their invitation, in three calm steps.
                  <strong>① Test</strong> sends one to you — open it and check it looks right.
                  <strong> ② Preview</strong> shows exactly who’ll get it.
                  <strong> ③ Send</strong> sends the real thing. No one is ever emailed twice, so you
                  can’t double up.
                </p>
                <div class="panel" data-panel data-count={pendingInvite}>
                  <p class="panel__head"><strong>{pendingInvite}</strong> ready to invite</p>
                  <div class="btns">
                    <button type="button" data-send data-type="invite" data-mode="test">① Test to us</button>
                    <button type="button" data-send data-type="invite" data-mode="dryRun">② Preview</button>
                    <button type="button" class="btn-go" data-send data-type="invite" data-mode="live">
                      ③ Send invitations
                    </button>
                  </div>
                  <p class="result" data-result aria-live="polite"></p>
                </div>
              </Fragment>
            )
          }
        </li>

        {/* ---- Step 3 — Track the replies ---- */}
        <li class:list={['step', `is-${step3}`]}>
          <div class="step__bar">
            <span class="step__num">3</span>
            <h2 class="step__title">Track the replies</h2>
            <span class="pill">{stepPill(step3)}</span>
          </div>
          <p class="step__hint">
            {hasList
              ? 'This is your guest list — and every reply lands here on its own, so there’s nothing to chase. Each household has its own private link (press Copy to re-send it by hand). As people reply you’ll see who’s coming, their meals and any allergies right here.'
              : 'Your guests will appear here once you’ve added the list in Step 1 — and it’s where their replies will land, too.'}
            {someInvited && outstanding > 0 &&
              ` ${responded.length} replied so far, ${outstanding} still to come — they save themselves, so just check back now and then.`}
            {someInvited && hasList && outstanding === 0 && ' Everyone you invited has replied. 🎉'}
            {paperGuests.length > 0 &&
              ` ${paperGuests.length} ${paperGuests.length === 1 ? 'household has' : 'households have'} no email — invite them by hand with the Copy button: ${paperGuests.map((h) => h.label).join(', ')}.`}
            {MEALS_ENABLED &&
              missingMeals > 0 &&
              ` ${missingMeals} ${missingMeals === 1 ? 'reply is' : 'replies are'} missing a meal (highlighted below).`}
          </p>
          {
            MEALS_ENABLED && attending.length > 0 && (
              <p class="muted">Meals — {mealTally.map((m) => `${m.label}: ${m.count}`).join('  ·  ')}</p>
            )
          }
          {hasList && (
            <div class="tablewrap">
              <table>
                <thead>
                  <tr>
                    <th>Household</th>
                    <th>Personal link</th>
                    <th>Email</th>
                    <th>Seats</th>
                    <th>Lang</th>
                    <th>Invite</th>
                    <th>Reply</th>
                    {MEALS_ENABLED && <th>Meals</th>}
                  </tr>
                </thead>
                <tbody>
                  {households.map((h) => (
                    <Fragment>
                      <tr
                        class:list={[
                          h.inviteStatus === 'sent' && !h.response && 'awaiting',
                          isMissingMeals(h) && 'missing',
                          replyIsStale(h) && 'stale',
                        ]}
                      >
                        <td>{h.label}</td>
                        <td>
                          <button type="button" class="copy" data-copy={householdLink(h.code, h.locale)}>
                            Copy
                          </button>
                          <code class="code">{h.code}</code>
                        </td>
                        <td>{h.email ?? '—'}</td>
                        <td>
                          {h.invitedGuests.length}
                          {h.plusOnes > 0 && <span class="muted-inline"> +{h.plusOnes}</span>}
                        </td>
                        <td>{h.locale}</td>
                        <td>{statusLabel(h.inviteStatus)}</td>
                        <td>
                          {h.response
                            ? h.response.attending === 'yes'
                              ? `Yes · ${h.response.partySize}`
                              : 'No'
                            : '— not yet'}
                          {replyIsStale(h) && (
                            <span class="flag" title="The guest list changed after this reply — re-check it.">
                              ⚠ list changed
                            </span>
                          )}
                        </td>
                        {MEALS_ENABLED && (
                          <td>
                            {h.response && h.response.attending === 'yes' ? (
                              <>
                                {rosterLines(h.response.roster, 'en').join(', ') || '—'}
                                {notComingNames(h.response.roster).length > 0 && (
                                  <span class="declined">
                                    {'  ·  '}
                                    {notComingNames(h.response.roster).join(', ')} can’t come
                                  </span>
                                )}
                              </>
                            ) : (
                              '—'
                            )}
                          </td>
                        )}
                      </tr>
                      {h.response && (h.response.dietary.trim() || h.response.message.trim()) && (
                        <tr class="notes-row">
                          <td colspan={MEALS_ENABLED ? 8 : 7}>
                            {h.response.dietary.trim() && (
                              <span class="note"><strong>Dietary</strong> {h.response.dietary.trim()}</span>
                            )}
                            {h.response.message.trim() && (
                              <span class="note"><strong>Message</strong> {h.response.message.trim()}</span>
                            )}
                          </td>
                        </tr>
                      )}
                    </Fragment>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </li>


        {/* ---- Step 4 — Send a reminder ---- */}
        <li class:list={['step', `is-${step4}`]}>
          <div class="step__bar">
            <span class="step__num">4</span>
            <h2 class="step__title">Send a reminder</h2>
            <span class="pill">{stepPill(step4)}</span>
          </div>
          {
            step4 === 'later' ? (
              <p class="step__hint">This is where you’ll nudge anyone who hasn’t replied. It unlocks once your invitations have gone out in Step 2.</p>
            ) : step4 === 'done' ? (
              <p class="step__hint">✓ Everyone has replied — no reminders needed.</p>
            ) : (
              <Fragment>
                <p class="step__hint">
                  This sends a gentle nudge to anyone who hasn’t replied yet — about a week before the
                  deadline is ideal. It’s the same three steps:
                  <strong>① Test</strong>, <strong>② Preview</strong>, <strong>③ Send</strong>. Anyone
                  who’s already replied — or was reminded in the last 12 hours — is skipped
                  automatically, so it’s always safe to press.
                </p>
                <div class="panel" data-panel data-count={remindable}>
                  <p class="panel__head">
                    <strong>{remindable}</strong> ready to remind{
                      outstanding > remindable && ` (${outstanding - remindable} in cooldown)`
                    }
                  </p>
                  <div class="btns">
                    <button type="button" data-send data-type="reminder" data-mode="test">① Test to us</button>
                    <button type="button" data-send data-type="reminder" data-mode="dryRun">② Preview</button>
                    <button type="button" class="btn-go" data-send data-type="reminder" data-mode="live">
                      ③ Send reminders
                    </button>
                  </div>
                  <p class="result" data-result aria-live="polite"></p>
                </div>
              </Fragment>
            )
          }
        </li>

        {/* ---- Step 5 — Give the caterer the numbers ---- */}
        <li class:list={['step', `is-${step5}`]}>
          <div class="step__bar">
            <span class="step__num">5</span>
            <h2 class="step__title">Give the caterer the numbers</h2>
            <span class="pill">{stepPill(step5)}</span>
          </div>
          <p class="step__hint">
            When it’s time to brief your caterer or venue, download the spreadsheet here. It lists
            every guest, whether they’re coming, their meal choice and any allergies, with your total
            headcount. Grab a fresh copy whenever you like — it’s always up to date.
          </p>
          <p><a class="dl" href="export.csv">Download the spreadsheet (CSV)</a></p>
          {
            MEALS_ENABLED && attending.length > 0 && (
              <p class="muted">Meals — {mealTally.map((m) => `${m.label}: ${m.count}`).join('  ·  ')}</p>
            )
          }
          {
            dietaryNotes.length > 0 && (
              <details class="fold">
                <summary>
                  {dietaryNotes.length}{' '}
                  {dietaryNotes.length === 1 ? 'allergy / dietary note' : 'allergy / dietary notes'}
                </summary>
                <ul class="diet">
                  {dietaryNotes.map((d) => (
                    <li>
                      <strong>{d.label}:</strong> {d.dietary}
                    </li>
                  ))}
                </ul>
              </details>
            )
          }
        </li>
      </ol>
    </main>

    <script>
      const postJSON = async (url: string, body: unknown) => {
        try {
          const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          let data: any = {};
          try {
            data = await res.json();
          } catch {
            /* ignore */
          }
          return { ok: res.ok, data };
        } catch {
          // Network failure — surface it instead of leaving the status spinning.
          return { ok: false, data: { error: 'Network error — check your connection and try again.' } };
        }
      };
      const esc = (s: unknown) =>
        String(s ?? '').replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' })[c] || c);

      // Send panels
      document.querySelectorAll<HTMLButtonElement>('[data-send]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const type = btn.dataset.type!;
          const mode = btn.dataset.mode!;
          const panel = btn.closest<HTMLElement>('[data-panel]')!;
          const out = panel.querySelector<HTMLElement>('[data-result]')!;
          if (mode === 'live') {
            const n = Math.min(Number(panel.dataset.count || '0'), 90);
            if (n === 0) {
              out.textContent = 'No one to send to.';
              return;
            }
            const word = type === 'invite' ? 'invitations' : 'reminders';
            if (!confirm(`Send ${word} to up to ${n} people now? This sends real email and can't be undone.`))
              return;
          }
          out.textContent = 'Working…';
          const { ok, data } = await postJSON('send/', { type, mode });
          if (!ok || data.error) {
            out.textContent = 'Error: ' + (data.error || 'failed');
            return;
          }
          if (data.tested) {
            out.textContent = `Test sent to ${data.to}. Check that inbox before a real send.`;
            return;
          }
          if (data.dryRun) {
            out.innerHTML =
              `<strong>Would send ${data.willSend.length}</strong> of ${data.totalPending} outstanding:<br>` +
              data.willSend.map((w: any) => `${esc(w.label)} — ${esc(w.to)}`).join('<br>');
            return;
          }
          out.textContent =
            `Sent ${data.sent}, failed ${data.failed}, ${data.remaining} remaining.` +
            (data.failed ? ' Check failures below and retry.' : '');
          setTimeout(() => location.reload(), 1800);
        });
      });

      // Import
      const csv = () => document.querySelector<HTMLTextAreaElement>('[data-csv]')!.value;
      const importOut = () => document.querySelector<HTMLElement>('[data-import-result]')!;

      // Upload a .csv (or .tsv/.txt) file → drop its text into the paste box and run
      // Preview automatically. Both feed the same parser (commas or tabs), so a CSV
      // export and a spreadsheet copy both work.
      const fileInput = document.querySelector<HTMLInputElement>('[data-csv-file]');
      const fileNameEl = document.querySelector<HTMLElement>('[data-csv-file-name]');
      fileInput?.addEventListener('change', () => {
        const file = fileInput.files?.[0];
        if (!file) return;
        if (/\.(xlsx|xls|numbers|ods)$/i.test(file.name)) {
          if (fileNameEl)
            fileNameEl.textContent = `“${file.name}” is a spreadsheet file — save it as CSV first (File → Save as / Download → CSV), then choose that.`;
          fileInput.value = '';
          return;
        }
        const reader = new FileReader();
        reader.onload = () => {
          document.querySelector<HTMLTextAreaElement>('[data-csv]')!.value = String(reader.result ?? '');
          if (fileNameEl) fileNameEl.textContent = `Loaded ${file.name}`;
          document.querySelector<HTMLButtonElement>('[data-import-preview]')?.click();
        };
        reader.onerror = () => {
          if (fileNameEl) fileNameEl.textContent = 'Could not read that file — try pasting instead.';
        };
        reader.readAsText(file);
      });

      document.querySelector('[data-import-preview]')?.addEventListener('click', async () => {
        importOut().textContent = 'Checking…';
        const { ok, data } = await postJSON('import/', { csv: csv(), dryRun: true });
        if (!ok || data.error) {
          importOut().textContent = 'Error: ' + (data.error || 'failed');
          return;
        }
        const bad = (data.preview as any[]).filter((r) => !r.valid);
        importOut().innerHTML =
          `<strong>${data.validCount} valid</strong> of ${data.total}.` +
          (bad.length
            ? `<br>${bad.length} to fix:<br>` +
              bad.map((r) => `line ${r.line}: ${esc(r.issue)} — ${esc(r.label)}`).join('<br>')
            : ' Ready to import.');
      });
      document.querySelector('[data-import-go]')?.addEventListener('click', async () => {
        if (
          !confirm(
            'Import this list now? Rows with errors are skipped — Preview first to review them. ' +
              'Existing households (matched by email) are updated.',
          )
        )
          return;
        importOut().textContent = 'Importing…';
        const { ok, data } = await postJSON('import/', { csv: csv() });
        if (!ok || data.error) {
          importOut().textContent = 'Error: ' + (data.error || 'failed');
          return;
        }
        let msg = `Imported ${data.inserted} new, ${data.updated} updated, ${data.skipped.length} skipped.`;
        const changed = data.changedAfterReply ?? [];
        if (changed.length) {
          // A household that already RSVP'd had its people/allowance changed — its
          // saved roster may now be stale. Keep this on screen instead of reloading.
          msg +=
            ` ⚠ ${changed.length} already-replied household${changed.length > 1 ? 's' : ''} changed (` +
            changed.map((c: { label: string }) => c.label).join(', ') +
            ') — reload and re-check their RSVP.';
          importOut().textContent = msg;
          return;
        }
        importOut().textContent = msg;
        setTimeout(() => location.reload(), 1800);
      });

      // Copy personal links
      document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(btn.dataset.copy!);
            const t = btn.textContent;
            btn.textContent = 'Copied';
            setTimeout(() => (btn.textContent = t), 1200);
          } catch {
            // Clipboard can fail (denied permission / insecure context) — don't
            // leave the couple thinking it copied. Offer the link to copy by hand.
            window.prompt('Copy this link:', btn.dataset.copy!);
          }
        });
      });
    </script>

