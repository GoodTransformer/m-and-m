      .step__bar {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        flex-wrap: wrap;
      }
      .step__num {
        flex: none;
        width: 1.9rem;
        height: 1.9rem;
        display: grid;
        place-items: center;
        font-family: var(--font-display, serif);
        font-size: 1rem;
        border-radius: 50%;
        border: 1px solid var(--rule-strong, #c9b79a);
        background: #fff;
        color: var(--text-muted, #6b5a4f);
