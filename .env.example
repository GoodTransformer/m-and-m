# Copy to `.env` for local dev, and set the same keys in Vercel for production.
# NEVER commit real secrets. Only the PUBLIC_ key is exposed to the browser.

# ── Site origin ──────────────────────────────────────────────────────────────
# Used to build absolute personal RSVP links in invitation emails and /admin.
# Dev: http://localhost:4321   Prod: your deployed origin (https://yourdomain).
SITE_URL=https://yourdomain

# ── Database (Turso / libSQL) ────────────────────────────────────────────────
# Dev: a local SQLite file.   Prod: your Turso database URL + token.
#   turso db create mari-and-michael
#   turso db show mari-and-michael --url      → TURSO_DATABASE_URL (libsql://…)
#   turso db tokens create mari-and-michael   → TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Create an API key at https://resend.com. To send from your own domain you must
# verify it (DNS records); until then you can send from onboarding@resend.dev to
# your own account address for testing. Leave the key empty to disable sending.
RESEND_API_KEY=
RSVP_FROM_EMAIL=Mari & Michael <rsvp@yourdomain>
COUPLE_NOTIFY_EMAIL=the-couple@yourdomain

# ── Anti-spam (Cloudflare Turnstile) ─────────────────────────────────────────
# Free, works on any host. Create a widget at https://dash.cloudflare.com → Turnstile.
# Test keys (always pass): sitekey 1x00000000000000000000AA,
#                          secret  1x0000000000000000000000000000000AA
PUBLIC_TURNSTILE_SITEKEY=
TURNSTILE_SECRET_KEY=

# ── Admin inbox (/admin) ─────────────────────────────────────────────────────
# HTTP Basic credentials the couple use to read replies. Use a long passphrase.
ADMIN_USER=mari
ADMIN_PASSCODE=
